# Copy this file to .env.production on the VPS and replace every placeholder.
ACME_EMAIL=owner@example.com
APP_IMAGE=ghcr.io/michalszwedo05/moderato-art:replace-with-commit-sha
DATABASE_URL=postgresql://moderato:replace-with-a-long-random-password@db:5432/moderato?schema=public
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-replace-with-your-public-key
LANGFUSE_RELEASE=replace-with-commit-sha
LANGFUSE_SAMPLE_RATE=0.2
LANGFUSE_SECRET_KEY=sk-lf-replace-with-your-secret-key
LANGFUSE_TRACING_ENVIRONMENT=production
POSTGRES_DB=moderato
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_USER=moderato
SITE_DOMAIN=moderato-art.pl
